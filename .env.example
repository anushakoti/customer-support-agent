# Copy this file to .env and fill in real values — never commit .env to git

# Required: OpenAI API key for LLM and embeddings
OPENAI_API_KEY=sk-...

# Required: Secret key used to authenticate /chat requests (set any strong random string)
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=your-strong-random-secret-here

# Optional: LangSmith tracing (https://smith.langchain.com)
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=customer-support-agent
